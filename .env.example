MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=trandia

JWT_SECRET_KEY=your-256-bit-secret-key-here
JWT_ALGORITHM=HS256
# BUG FIX: Reduced from 10080 (7 days) to 60 minutes.
# Long-lived tokens are a security risk — a stolen token was valid for a week.
JWT_EXPIRE_MINUTES=60

GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

FIREBASE_CREDENTIALS_PATH=your-firebase-adminsdk.json

# REQUIRED — must be a strong random string (min 16 chars).
# BUG FIX: Was hardcoded to "trandia-secret-key" in config.py.
# Used to sign OAuth state — a weak value enables CSRF on the Google OAuth flow.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=your-strong-random-secret-here

# Comma-separated list of Flutter web origins allowed to receive OAuth redirects.
# BUG FIX: Added to prevent open-redirect attacks that would leak JWT tokens.
# Example: http://localhost:59236,https://trandia.app
# Leave empty to allow only localhost (safe for local dev).
ALLOWED_ORIGINS=
